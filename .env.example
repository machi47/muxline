# Private Tailnet hub (any always-on Tailnet device)
MUXLINE_AUTH_MODE=tailscale
MUXLINE_HUB_AGENT_TOKEN=replace-with-at-least-32-random-characters
MUXLINE_ALLOWED_TAILSCALE_USERS=you@example.com
MUXLINE_HUB_PORT=7338
# Optional durable hub catalogue location (defaults to ~/.muxline-hub)
# MUXLINE_HUB_HOME=/path/to/private/muxline-hub

# macOS or Windows host agent
MUXLINE_HUB_URL=https://your-muxline-hub.your-tailnet.ts.net
MUXLINE_HUB_TOKEN=replace-with-the-same-agent-token

# Optional display names
# MUXLINE_HOST_NAME=workstation
# MUXLINE_LOG_LEVEL=info
