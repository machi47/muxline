# M1 hub
MUXLINE_AUTH_MODE=tailscale
MUXLINE_HUB_AGENT_TOKEN=replace-with-at-least-32-random-characters
MUXLINE_ALLOWED_TAILSCALE_USERS=you@example.com
MUXLINE_HUB_PORT=7338

# M4 / Windows host agent
MUXLINE_HUB_URL=https://your-m1.your-tailnet.ts.net
MUXLINE_HUB_TOKEN=replace-with-the-same-agent-token

# Optional display names
# MUXLINE_HOST_NAME=M4 Max
# MUXLINE_LOG_LEVEL=info
